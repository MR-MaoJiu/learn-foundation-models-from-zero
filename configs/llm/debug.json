{
  "model": {
    "vocab_size": 1024,
    "max_seq_len": 1024,
    "n_layer": 4,
    "n_head": 4,
    "n_embd": 128,
    "intermediate_size": 512,
    "dropout": 0.1,
    "rope_theta": 10000.0
  },
  "training": {
    "tokenizer_path": "artifacts/llm/tokenizer/tokenizer.json",
    "train_bin": "data/text/processed/train.bin",
    "val_bin": "data/text/processed/val.bin",
    "output_dir": "checkpoints/llm/debug",
    "batch_size": 16,
    "micro_batch_size": 4,
    "max_steps": 200,
    "learning_rate": 0.0006,
    "min_learning_rate": 0.00006,
    "warmup_steps": 20,
    "weight_decay": 0.1,
    "grad_clip": 1.0,
    "eval_interval": 50,
    "eval_iters": 10,
    "log_interval": 10,
    "save_interval": 100,
    "seed": 42,
    "device": "auto",
    "dtype": "auto"
  }
}
