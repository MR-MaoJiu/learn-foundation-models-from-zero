{
  "model": {
    "vocab_size": 2048,
    "max_seq_len": 1024,
    "n_layer": 12,
    "n_head": 8,
    "n_embd": 512,
    "intermediate_size": 2048,
    "dropout": 0.1,
    "rope_theta": 10000.0
  },
  "training": {
    "tokenizer_path": "artifacts/llm/tokenizer/tokenizer.json",
    "train_bin": "data/text/processed/train.bin",
    "val_bin": "data/text/processed/val.bin",
    "output_dir": "checkpoints/llm/gpt_50m_8gb",
    "batch_size": 32,
    "micro_batch_size": 2,
    "max_steps": 2000,
    "learning_rate": 0.0004,
    "min_learning_rate": 0.00004,
    "warmup_steps": 100,
    "weight_decay": 0.1,
    "grad_clip": 1.0,
    "eval_interval": 200,
    "eval_iters": 20,
    "log_interval": 10,
    "save_interval": 500,
    "seed": 42,
    "device": "auto",
    "dtype": "auto"
  }
}
