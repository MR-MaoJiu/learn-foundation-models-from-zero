{
  "model": {
    "vocab_size": 1024,
    "max_seq_len": 1024,
    "n_layer": 4,
    "n_head": 4,
    "n_embd": 128,
    "intermediate_size": 512,
    "dropout": 0.1,
    "rope_theta": 10000.0
  },
  "training": {
    "base_checkpoint": "checkpoints/llm/debug/last.pt",
    "tokenizer_path": "artifacts/llm/tokenizer/tokenizer.json",
    "sft_jsonl": "data/text/raw/sft_chat_zh.jsonl",
    "output_dir": "checkpoints/llm/sft_debug",
    "batch_size": 16,
    "micro_batch_size": 4,
    "max_steps": 240,
    "learning_rate": 0.0001,
    "min_learning_rate": 0.00001,
    "warmup_steps": 10,
    "weight_decay": 0.01,
    "grad_clip": 1.0,
    "eval_interval": 60,
    "eval_iters": 5,
    "log_interval": 5,
    "save_interval": 120,
    "val_ratio": 0.2,
    "seed": 42,
    "device": "auto",
    "dtype": "auto"
  }
}
